GROQ_API_KEY=                     # Free key at console.groq.com
SMTP_HOST=                        # SMTP server host
SMTP_PORT=                        # SMTP port (e.g. 587)
SMTP_USER=                        # Your email address
SMTP_PASS=                        # Your email password or app password
ALLOWED_COMMANDS=                 # Comma-separated safe shell commands (e.g. ls,pwd,echo)
SENDGRID_API_KEY=                 # Optional: SendGrid API key for email in production
ENABLE_LOCAL_TOOLS=true           # Set to true to enable local tools (read_file, write_file, run_command)
DATABASE_URL=                     # Optional: PostgreSQL URL for production. Defaults to SQLite (autoagent.db) if empty